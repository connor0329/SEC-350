firewall {
    ipv4 {
        name DMZ-to-LAN {
            default-action drop
            default-log
            rule 1 {
                action accept
                description "DMZ back out to LAN"
                state established
            }
            rule 10 {
                action accept
                description "Allow Wazuh Agent to Server"
                destination {
                    address 172.16.200.10
                    port 1514,1515
                }
                protocol tcp
            }
        }
        name DMZ-to-WAN {
            default-action drop
            default-log
            description "DMZ back out to WAN"
            rule 1 {
                action accept
                description "DMZ back out to WAN"
                state established
            }
        }
        name LAN-to-DMZ {
            default-action drop
            default-log
            rule 1 {
                action accept
                description "LAN back out to DMZ"
                state established
            }
            rule 10 {
                action accept
                description "Allow HTTP from LAN to web01"
                destination {
                    address 172.16.50.3
                    port 80
                }
                protocol tcp
            }
            rule 20 {
                action accept
                description "Allow SSH from mgmt01 to DMZ"
                destination {
                    address 172.16.50.0/29
                    port 22
                }
                protocol tcp
                source {
                    address 172.16.150.10
                }
            }
        }
        name LAN-to-WAN {
            default-action drop
            default-log
            rule 1 {
                action accept
            }
        }
        name WAN-to-DMZ {
            default-action drop
            default-log
            rule 1 {
                action accept
                description "WAN back out to DMZ"
                state established
            }
            rule 10 {
                action accept
                description "Allow HTTP from WAN to DMZ"
                destination {
                    address 172.16.50.3
                    port 80
                }
                protocol tcp
            }
            rule 20 {
                action accept
                description "Allow SSH from WAN to JUMP"
                destination {
                    address 172.16.50.4
                    port 22
                }
                protocol tcp
                source {
                    address 10.0.17.0/24
                }
            }
        }
        name WAN-to-LAN {
            default-action drop
            default-log
            rule 1 {
                action accept
                description "WAN back to LAN"
                state established
            }
        }
    }
    zone DMZ {
        from LAN {
            firewall {
                name LAN-to-DMZ
            }
        }
        from WAN {
            firewall {
                name WAN-to-DMZ
            }
        }
        member {
            interface eth1
        }
    }
    zone LAN {
        from DMZ {
            firewall {
                name DMZ-to-LAN
            }
        }
        from WAN {
            firewall {
                name WAN-to-LAN
            }
        }
        member {
            interface eth2
        }
    }
    zone WAN {
        from DMZ {
            firewall {
                name DMZ-to-WAN
            }
        }
        from LAN {
            firewall {
                name LAN-to-WAN
            }
        }
        member {
            interface eth0
        }
    }
}
interfaces {
    ethernet eth0 {
        address 10.0.17.118/24
        description SEC350-WAN
        hw-id bc:24:11:d7:5d:9d
        offload {
            gro
            gso
            sg
            tso
        }
    }
    ethernet eth1 {
        address 172.16.50.2/29
        description CONNOR-DMZ
        hw-id bc:24:11:28:22:cb
    }
    ethernet eth2 {
        address 172.16.150.2/24
        description CONNOR-LAN
        hw-id bc:24:11:47:db:bb
    }
    loopback lo {
    }
}
nat {
    destination {
        rule 10 {
            description HTTP->WEB01
            destination {
                port 80
            }
            inbound-interface {
                name eth0
            }
            protocol tcp
            translation {
                address 172.16.50.3
                port 80
            }
        }
        rule 20 {
            description SSH->JUMP
            destination {
                port 22
            }
            inbound-interface {
                name eth0
            }
            protocol tcp
            translation {
                address 172.16.50.4
                port 22
            }
        }
    }
    source {
        rule 10 {
            description "NAT FROM DMZ to WAN"
            outbound-interface {
                name eth0
            }
            source {
                address 172.16.50.0/29
            }
            translation {
                address masquerade
            }
        }
        rule 20 {
            description "NAT FROM DMZ to LAN"
            outbound-interface {
                name eth0
            }
            source {
                address 172.16.150.0/24
            }
            translation {
                address masquerade
            }
        }
        rule 30 {
            description "NAT FROM MGMT to WAN"
            outbound-interface {
                name eth0
            }
            source {
                address 172.16.200.0/28
            }
            translation {
                address masquerade
            }
        }
    }
}
protocols {
    rip {
        interface eth2 {
        }
        network 172.16.50.0/29
    }
    static {
        route 0.0.0.0/0 {
            next-hop 10.0.17.2 {
            }
        }
    }
}
service {
    dns {
        forwarding {
            allow-from 172.16.50.0/29
            allow-from 172.16.150.0/24
            allow-from 172.16.200.0/28
            listen-address 172.16.50.2
            listen-address 172.16.150.2
            listen-address 172.16.200.2
            system
        }
    }
    ntp {
        allow-client {
            address 127.0.0.0/8
            address 169.254.0.0/16
            address 10.0.0.0/8
            address 172.16.0.0/12
            address 192.168.0.0/16
            address ::1/128
            address fe80::/10
            address fc00::/7
        }
        server time1.vyos.net {
        }
        server time2.vyos.net {
        }
        server time3.vyos.net {
        }
    }
    ssh {
        listen-address 172.16.150.2
        port 22
    }
}
system {
    config-management {
        commit-revisions 100
    }
    console {
        device ttyS0 {
            speed 115200
        }
    }
    host-name fw01-connor
    login {
        operator-group default {
            command-policy {
                allow "*"
            }
        }
        user deployer {
            authentication {
                encrypted-password ****************
            }
            full-name deployer
        }
        user newuser {
            full-name deployer
        }
        user newuswer {
            disable
        }
        user vyos {
            authentication {
                encrypted-password ****************
                plaintext-password ****************
            }
        }
    }
    name-server 10.0.17.2
    option {
        reboot-on-upgrade-failure 5
    }
    syslog {
        local {
            facility all {
                level info
            }
            facility local7 {
                level debug
            }
        }
    }
